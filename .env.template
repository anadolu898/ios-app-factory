# ============================================================
# iOS App Factory — API Keys & Credentials
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- Appeeky (ASO Intelligence) ---
# Sign up at https://appeeky.com, get API key from dashboard
APPEEKY_API_KEY=

# --- App Store Connect ---
# Create API key at https://appstoreconnect.apple.com/access/integrations/api
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_P8_PATH=/path/to/AuthKey_XXXXXX.p8

# --- RevenueCat ---
# Get API key from https://app.revenuecat.com/settings/api-keys
REVENUECAT_API_KEY=

# --- Twitter/X API ---
# Apply at https://developer.twitter.com
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- ElevenLabs (Video Voiceover) ---
# Get key from https://elevenlabs.io
ELEVENLABS_API_KEY=

# --- Creatomate (Video Generation) ---
# Get key from https://creatomate.com
CREATOMATE_API_KEY=

# --- Sentry (Crash Monitoring) ---
# Get DSN from https://sentry.io
SENTRY_DSN=
